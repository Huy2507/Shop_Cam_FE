{
  "name": "shop-cam-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:storefront": "tsc -b && vite build --config vite.config.ts --outDir dist-storefront --emptyOutDir=false --ssrManifest=false --manifest=true --base=/",
    "build:admin": "tsc -b && vite build --config vite.config.ts --outDir dist-admin --emptyOutDir=false --ssrManifest=false --manifest=true --base=/ --ssrManifest=false --name=admin --input=admin.html",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepare": "husky",
    "format": "prettier --write .",
    "docker:build": "docker build -t shop_cam_fe .",
    "docker:run": "docker run -d -p 80:80 shop_cam_fe"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "dayjs": "^1.11.13",
    "i18next": "^25.2.1",
    "i18next-browser-languagedetector": "^8.1.0",
    "lucide-react": "^0.513.0",
    "react": "^19.1.0",
    "react-datepicker": "^8.4.0",
    "react-dom": "^19.1.0",
    "react-hot-toast": "^2.5.2",
    "react-i18next": "^15.5.2",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.6.2",
    "react-tailwindcss-datepicker": "^2.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.25.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "postcss": "^8.5.4",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "tailwindcss": "^3.4.16",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-plugin-minify": "^2.1.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,html,css,json,md}": "prettier --write"
  }
}
