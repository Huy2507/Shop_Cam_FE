# --- API ---
# Cách A (khuyên khi dev FE trên localhost): để trống VITE_API_URL để gọi /api cùng origin,
# Vite proxy chuyển tiếp tới BE (tránh lỗi CORS). Ưu tiên HTTPS (tránh redirect http→https):
# VITE_DEV_API_PROXY_TARGET=https://kyoozed-001-site1.ktempurl.com
#
# SmarterASP bật "Password Protection" trên URL tạm → Basic Auth chặn cả OPTIONS (giống lỗi CORS).
# Điền user:pass từ panel (không commit .env). Chỉ áp khi dùng proxy (VITE_API_URL trống).
# DEV_PROXY_BASIC_AUTH=so-tu-panel:mat-khau-tu-panel
#
# Cách B: gọi thẳng BE (cần CORS trên server cho http://localhost:5173):
# VITE_API_URL=http://localhost:5000
VITE_API_URL=
VITE_DEV_API_PROXY_TARGET=http://localhost:5000

# Zalo — có thể cấu hình trong Admin → Cấu hình site → Zalo (lưu DB, ưu tiên hơn env).
# Dùng env khi dev không gọi API hoặc fallback:
# VITE_ZALO_OA_ID=
# VITE_ZALO_CHAT_URL=https://zalo.me/84901234567
# VITE_ZALO_WELCOME_MESSAGE=Shop Cam xin chào!
